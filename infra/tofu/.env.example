# ─────────────────────────────────────────────────────────────
# infra/tofu/.env — variáveis para provisionar a VPS (OpenTofu)
# Copie para .env e preencha. NUNCA commite o .env preenchido.
# Uso:  set -a && source .env && set +a && tofu plan
# (pode manter na raiz do repo; basta `source` antes de rodar o tofu)
# ─────────────────────────────────────────────────────────────

# ===== 1. Credenciais AWS (OBRIGATÓRIO) =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=mirante         # alternativa às 2 chaves acima
AWS_REGION=sa-east-1

# ===== 2. Acesso SSH (OBRIGATÓRIO) =====
# Caminho do arquivo da chave PÚBLICA (~ é expandido).
TF_VAR_ssh_public_key_path=~/.ssh/id_ed25519.pub

# CIDRs liberados p/ SSH(22) + portas de auditoria. Web 80/443 fica público.
# Formato HCL/JSON. Ex.: seu IP /32 (curl -s ifconfig.me)
TF_VAR_allowed_ingress_cidrs='["SEU_IP/32"]'

# ===== 3. Cloudflare DNS (OBRIGATÓRIO) =====
# Token escopado à zona, permissão DNS:Edit (NÃO global).
TF_VAR_cloudflare_api_token=
TF_VAR_cloudflare_zone_name=mirantegov.cloud
# TF_VAR_app_subdomain=painel        # cria painel.mirantegov.cloud
# proxied=false p/ ACME HTTP-01 do Traefik funcionar
TF_VAR_cloudflare_proxied=false

# ===== 4. Git clone na instância =====
TF_VAR_git_repo_url=https://github.com/mirantegov/painel.git
TF_VAR_git_ref=main
# PAT fine-grained READ-ONLY só deste repo (repo privado). Vazio = público.
TF_VAR_github_token=

# ===== 5. App / overrides opcionais =====
TF_VAR_app_secret_key=
# TF_VAR_aws_region=sa-east-1
# TF_VAR_instance_type=t3.xlarge       # ou m5.xlarge / t3.large
# TF_VAR_root_volume_gb=160
