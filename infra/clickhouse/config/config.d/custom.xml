<?xml version="1.0"?>
<!-- Override de configuração do servidor ClickHouse (SIM-AM). -->
<clickhouse>
    <logger>
        <level>information</level>
        <log>/var/log/clickhouse-server/clickhouse-server.log</log>
        <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
        <size>200M</size>
        <count>5</count>
    </logger>

    <!-- Escuta em todas as interfaces dentro do container. -->
    <listen_host>0.0.0.0</listen_host>

    <http_port>8123</http_port>
    <tcp_port>9000</tcp_port>

    <!-- Caminhos de dados (mapeados para o volume ./data). -->
    <path>/var/lib/clickhouse/</path>
    <tmp_path>/var/lib/clickhouse/tmp/</tmp_path>
    <user_files_path>/var/lib/clickhouse/user_files/</user_files_path>
    <format_schema_path>/var/lib/clickhouse/format_schemas/</format_schema_path>

    <!-- Timezone do TCE-PR. -->
    <timezone>America/Sao_Paulo</timezone>

    <!-- Permite ler/gravar Parquet/S3 (MinIO) sem restrição de host. -->
    <merge_tree>
        <allow_remote_fs_zero_copy_replication>0</allow_remote_fs_zero_copy_replication>
    </merge_tree>
</clickhouse>
