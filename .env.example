# ─────────────────────────────────────────────────────────────
# Mirante Painel — variáveis de ambiente (copie para .env e preencha)
# NUNCA preencha segredos reais neste arquivo: ele é versionado (público).
# ─────────────────────────────────────────────────────────────

# Chave SSH local (pública) que será instalada no EC2.
TF_VAR_ssh_public_key_path="$HOME/.ssh/id_ed25519.pub"

# Postgres (Supabase self-hosted). Default = stack local do Supabase CLI.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Auth custom (JWT em cookie httpOnly). GERE UM SEGREDO FORTE (>=32 chars).
JWT_SECRET=""
AUTH_COOKIE_NAME="mp_session"

# Supabase (opcional — Studio/Data API). Preenchidos por `supabase start`.
# SUPABASE_URL="http://127.0.0.1:54321"
# SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

# MinIO / S3 (camada de pipeline — Épico 4). Usado pelo exportador (exporter/).
# Defaults batem com infra/docker-compose.minio.yml.
S3_ENDPOINT="http://127.0.0.1:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="mirante-parquet"

# ngrok (expor o MinIO local — testes de importação). Conta grátis em ngrok.com.
# NGROK_AUTHTOKEN=""


# --- AWS account ------------------------------------------------------------
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

TF_VAR_aws_region="us-east-1"
TF_VAR_instance_type="t3.xlarge"

# --- Secrets injetados via user-data no EC2 ---------------------------------
TF_VAR_app_secret_key=""

# --- CIDRs liberados para acesso aos serviços (HTTP/HTTPS, SSH, etc.) --------
# Formato lista HCL/JSON. Ex.: ["SEU_IP/32"] (curl -s ifconfig.me)
TF_VAR_allowed_ingress_cidrs='["SEU_IP/32"]'

# --- Repo / deploy ----------------------------------------------------------
TF_VAR_git_repo_url="https://github.com/mirantegov/painel.git"
TF_VAR_git_ref="main"
# PAT fine-grained READ-ONLY só deste repo (repo privado). Vazio = público.
TF_VAR_github_token=""

# --- Cloudflare DNS Zone ----------------------------------------------------
# Token escopado à zona, permissão DNS:Edit (NÃO global).
TF_VAR_cloudflare_api_token=""
TF_VAR_cloudflare_zone_name="mirantegov.cloud"
TF_VAR_cloudflare_proxied="false"
