# ─────────────────────────────────────────────────────────────
# Mirante Painel — variáveis de ambiente (copie para .env.local)
# ─────────────────────────────────────────────────────────────

# Postgres (Supabase self-hosted). Default = stack local do Supabase CLI.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Auth custom (JWT em cookie httpOnly). GERE UM SEGREDO FORTE em produção.
JWT_SECRET="dev-only-change-me-please-32+chars-secret"
AUTH_COOKIE_NAME="mp_session"

# Supabase (opcional — Studio/Data API). Preenchidos por `supabase start`.
# SUPABASE_URL="http://127.0.0.1:54321"
# SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

# MinIO / S3 (camada de pipeline — Épico 4). Usado pelo exportador (exporter/).
# Defaults batem com infra/docker-compose.minio.yml.
S3_ENDPOINT="http://127.0.0.1:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="mirante-parquet"

# ngrok (expor o MinIO local — testes de importação). Conta grátis em ngrok.com.
# NGROK_AUTHTOKEN=""
