# TEMPLATE de SEGREDOS — copie para <ibge>.secret.env e preencha.
# NUNCA versionar: *.secret.env é gitignored. chmod 600 recomendado.
#
#   cp _TEMPLATE.secret.env 4117107.secret.env && chmod 600 4117107.secret.env

# Banco do ERP Elotech (acessível da máquina que roda o cron — normalmente local).
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/NOME_DO_BANCO"

# MinIO da VPS (chaves em docs/ACESSOS.local.md, fora do Git).
S3_ENDPOINT="https://minio.mirantegov.cloud"
S3_BUCKET="mirante-parquet"
S3_ACCESS_KEY="PREENCHA"
S3_SECRET_KEY="PREENCHA"
